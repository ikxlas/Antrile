#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ==========================================
# SENSITIVE FILES & CREDENTIALS (API KEYS, TOKENS, Dsb)
# ==========================================

# File Environment (Variabel Rahasia)
.env
.env.*

# File Keystore & Properti Signing Android (Agar tidak bocor saat rilis)
*.jks
*.keystore
android/key.properties
android/app/key.properties

# Konfigurasi Firebase (Mencegah Ekspos API Key, App ID, dsb)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist

# File opsi Firebase yang ter-generate otomatis 
lib/firebase_options.dart

# Sertifikat dan Keys Lainnya
*.key
*.pem
*.p12
*.cer
*.cert
secrets/

# Kredensial tambahan (Service Accounts GCP, dsb)
*ServiceAccount*.json
*credentials*.json
*api-*.json
